{
  "name": "worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace web",
    "prebuild": "node ../../scripts/generate-web-content.mjs",
    "predeploy": "node ../../scripts/generate-web-content.mjs",
    "dev": "WRANGLER_LOG_PATH=/tmp/wrangler-dev.log wrangler dev --config ../../wrangler.toml",
    "test": "node --test src/tests/*.test.ts",
    "build": "WRANGLER_LOG_PATH=/tmp/wrangler.log wrangler deploy --config ../../wrangler.toml --dry-run",
    "deploy": "WRANGLER_LOG_PATH=/tmp/wrangler.log wrangler deploy --config ../../wrangler.toml"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "wrangler": "^3.86.0"
  }
}
